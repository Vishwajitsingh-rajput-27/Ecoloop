# ═══════════════════════════════════════════════════════════════
# EcoLoop — Environment Variables (Example)
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → Node.js
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/ecoloop?retryWrites=true&w=majority&appName=Cluster0

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── JWT Authentication ─────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRES_IN=7d

# ── Razorpay Payments ─────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Frontend ───────────────────────────────────────────────────
# URL of the backend API (used by Vite frontend)
VITE_API_URL=http://localhost:3001
